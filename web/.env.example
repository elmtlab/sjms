# Server-only URL for the local media service. Do not expose it with NEXT_PUBLIC_.
MEDIA_API_URL=http://127.0.0.1:8787

# Persistent project and upload storage for the single-server MVP.
SJMS_DATA_DIR=./data

# The understanding worker currently defaults to deterministic mock output.
VISION_PROVIDER=mock

# Set after services/understand is running. Leave empty for the in-process mock.
# UNDERSTANDING_API_URL=http://127.0.0.1:8788
